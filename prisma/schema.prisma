generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Message {
  id          String   @id @default(cuid())
  content     String   @db.VarChar(500)
  tag         String?  @db.VarChar(10)
  bottleColor String?  @db.VarChar(10)
  paperStyle  String?  @db.VarChar(10)
  heartCount  Int      @default(0)
  reportCount Int      @default(0)
  isDeleted   Boolean  @default(false)
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@index([expiresAt])
  @@index([isDeleted, expiresAt])
  @@index([tag, isDeleted, expiresAt])
}
